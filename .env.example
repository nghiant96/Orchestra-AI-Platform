# =============================================================================
# Orchestra AI Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# The server reads .env from the repo root automatically at startup.

# ---------------------------------------------------------------------------
# Provider Selection
# ---------------------------------------------------------------------------
# AI_SYSTEM_PROVIDER=9router          # Force a specific provider (9router, local-cli, etc.)
# AI_SYSTEM_API_KEY=sk-...            # API key for 9router / openai-compatible providers
# AI_SYSTEM_BASE_URL=http://127.0.0.1:20128/v1  # Override base URL for API providers
# AI_SYSTEM_MODEL=ag/gemini-3.1-pro-high        # Override the default model

# AI_SYSTEM_ROUTING_PROFILE=balanced  # balanced | quality | speed | cost
# AI_SYSTEM_MEMORY=local              # off | local-file | openmemory
# AI_SYSTEM_MEMORY=openmemory         # Use OpenMemory backend
# AI_SYSTEM_OPENMEMORY_BASE_URL=http://127.0.0.1:9080
# AI_SYSTEM_OPENMEMORY_API_KEY=apikey-openmemory

# ---------------------------------------------------------------------------
# Server Mode
# ---------------------------------------------------------------------------
# AI_SYSTEM_SERVER_MODE=true                     # Enable HTTP server mode
AI_SYSTEM_SERVER_TOKEN=your-long-random-token    # REQUIRED in server mode — bearer token for API auth
# PORT=3927                                      # HTTP port (also AI_SYSTEM_PORT)
# AI_SYSTEM_PORT=3927
# AI_SYSTEM_WORKDIR=/absolute/path/to/repo        # Default working directory
# AI_SYSTEM_ALLOWED_WORKDIRS=/repo/a,/repo/b      # Comma-separated whitelist of allowed workdirs
# AI_SYSTEM_QUEUE_CONCURRENCY=1                   # Max concurrent job executions

# ---------------------------------------------------------------------------
# Long-Running Agent Settings
# ---------------------------------------------------------------------------
# Timeouts in milliseconds (0 = no timeout)
AI_SYSTEM_GENERATOR_TIMEOUT_MS=0
AI_SYSTEM_FIXER_TIMEOUT_MS=0
AI_SYSTEM_GENERATOR_MONITOR_INTERVAL_MS=60000
AI_SYSTEM_FIXER_MONITOR_INTERVAL_MS=60000

# ---------------------------------------------------------------------------
# Tool / Sandbox
# ---------------------------------------------------------------------------
# AI_SYSTEM_SANDBOX=inherit           # inherit | clean | docker
# AI_SYSTEM_DISABLE_TUI=false         # Set true to disable interactive TUI