{
  "memory": {
    "enabled": true,
    "backend": "openmemory"
  },
  "vector_search": {
    "enabled": true,
    "data_dir": ".ai-system-vector",
    "max_results": 4,
    "max_indexed_files": 200,
    "max_file_bytes": 65536,
    "chunk_size": 1200,
    "chunk_overlap": 200,
    "ignore_patterns": [
      ".ai-system-server/**",
      ".ai-system-artifacts/**",
      ".ai-system-memory/**",
      "**/node_modules/**",
      "**/*.json"
    ]
  },
  "profile": "hybrid",
  "max_iterations": 3,
  "providers": {
    "planner": {
      "model": ""
    },
    "reviewer": {
      "model": ""
    },
    "generator": {
      "model": ""
    },
    "fixer": {
      "model": ""
    }
  }
}
