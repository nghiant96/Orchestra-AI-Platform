{
  "max_iterations": 3,
  "max_files": 5,
  "max_write_files": 8,
  "token_limit_hint": 12000,
  "max_tree_entries": 400,
  "max_context_bytes": 60000,
  "request_timeout_ms": 60000,
  "request_retries": 3,
  "retry_base_delay_ms": 500,
  "artifacts": {
    "enabled": true,
    "data_dir": ".ai-system-artifacts"
  },
  "memory": {
    "enabled": true,
    "backend": "local-file",
    "data_dir": ".ai-system-memory",
    "max_results": 4,
    "max_prompt_chars": 1600,
    "max_entries": 500,
    "transport": "http",
    "base_url": "http://127.0.0.1:9080",
    "api_key": "1112112213mm123m12m31m23123n1n3",
    "command": "opm",
    "health_timeout_ms": 10000,
    "query_timeout_ms": 15000,
    "store_timeout_ms": 15000
  },
  "vector_search": {
    "enabled": false,
    "data_dir": ".ai-system-vector",
    "max_results": 4,
    "max_indexed_files": 200,
    "max_file_bytes": 65536,
    "chunk_size": 1200,
    "chunk_overlap": 200
  },
  "routing": {
    "enabled": true,
    "default_profile": "balanced",
    "adaptive": {
      "enabled": true,
      "lookback_runs": 12,
      "min_samples": 2,
      "failure_weight": 1.5,
      "planner_weight": 1,
      "reviewer_weight": 1.5,
      "generator_weight": 0.75,
      "fixer_weight": 0.75,
      "role_override_threshold": 1.5,
      "latency_weight": 0.15,
      "cost_weight": 0.1
    },
    "profiles": {
      "fast": {
        "planner": "gemini-cli",
        "reviewer": "codex-cli",
        "generator": "codex-cli",
        "fixer": "codex-cli"
      },
      "balanced": {
        "planner": "gemini-cli",
        "reviewer": "gemini-cli",
        "generator": "codex-cli",
        "fixer": "codex-cli"
      },
      "safe": {
        "planner": "gemini-cli",
        "reviewer": "claude-cli",
        "generator": "codex-cli",
        "fixer": "codex-cli"
      }
    },
    "heuristics": {
      "fast": [
        "readme",
        "docs",
        "documentation",
        "comment",
        "comments",
        "typo",
        "wording",
        "copy",
        "text",
        "logging"
      ],
      "safe": [
        "auth",
        "permission",
        "security",
        "secret",
        "token",
        "credential",
        "payment",
        "billing",
        "checkout",
        "database",
        "db",
        "schema",
        "migration",
        "sql",
        "production",
        "deploy",
        "delete",
        "drop"
      ]
    }
  },
  "tools": {
    "enabled": true,
    "json_validation": true,
    "commands": {
      "lint": {
        "enabled": true,
        "timeout_ms": 120000
      },
      "typecheck": {
        "enabled": true,
        "timeout_ms": 120000
      },
      "build": {
        "enabled": false,
        "timeout_ms": 180000
      },
      "test": {
        "enabled": false,
        "timeout_ms": 180000
      }
    }
  },
  "providers": {
    "planner": {
      "type": "gemini-cli",
      "command": "gemini",
      "timeout_ms": 0,
      "retries": 2,
      "monitor_interval_ms": 0
    },
    "reviewer": {
      "type": "gemini-cli",
      "command": "gemini",
      "timeout_ms": 0,
      "retries": 2,
      "monitor_interval_ms": 0
    },
    "generator": {
      "type": "codex-cli",
      "command": "codex",
      "timeout_ms": 0,
      "retries": 1,
      "monitor_interval_ms": 60000
    },
    "fixer": {
      "type": "codex-cli",
      "command": "codex",
      "timeout_ms": 0,
      "retries": 1,
      "monitor_interval_ms": 60000
    },
    "claude_fallback": {
      "type": "claude-cli",
      "command": "claude",
      "timeout_ms": 0,
      "retries": 1,
      "monitor_interval_ms": 60000
    },
    "openai_compatible_example": {
      "type": "openai-compatible",
      "base_url": "http://127.0.0.1:20128/v1",
      "api_key": "",
      "model": "model-from-your-9router-dashboard",
      "timeout_ms": 0,
      "retries": 2,
      "monitor_interval_ms": 0
    }
  },
  "excluded_directories": [
    ".git",
    ".ai-system-artifacts",
    ".ai-system-memory",
    ".ai-system-vector",
    "node_modules",
    "ios/Pods",
    "android/build",
    "dist",
    "build",
    "coverage"
  ],
  "sensitive_file_names": [
    ".env",
    ".env.local",
    ".env.production",
    ".env.development",
    "id_rsa",
    "id_ed25519"
  ]
}
