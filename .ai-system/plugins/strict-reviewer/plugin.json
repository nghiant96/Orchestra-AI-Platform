{
  "name": "strict-reviewer",
  "version": "1.0.0",
  "description": "Adds strict security and performance audits to the review process.",
  "tools": {
    "security-audit": {
      "command": "pnpm",
      "args": ["audit", "--audit-level", "high", "--registry", "https://registry.npmjs.org"],
      "enabled": true,
      "timeout_ms": 60000
    }
  }
}
