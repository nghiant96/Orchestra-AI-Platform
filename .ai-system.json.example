{
  "max_iterations": 2,
  "max_files": 4,
  "memory": {
    "enabled": true,
    "backend": "local-file"
  },
  "providers": {
    "planner": {
      "type": "gemini-cli"
    },
    "reviewer": {
      "type": "gemini-cli"
    },
    "generator": {
      "type": "gemini-cli",
      "timeout_ms": 0
    },
    "fixer": {
      "type": "gemini-cli",
      "timeout_ms": 0
    }
  }
}
