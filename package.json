{
  "name": "ai-coding-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --import tsx ai-system/cli.ts",
    "server": "node --import tsx ai-system/server.ts",
    "ai": "node --import tsx ai-system/cli.ts",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "ai:local": "AI_SYSTEM_PROVIDER=local-cli node --import tsx ai-system/cli.ts",
    "ai:9router": "AI_SYSTEM_PROVIDER=9router node --import tsx ai-system/cli.ts",
    "ai:chat": "node --import tsx ai-system/cli.ts --chat",
    "ai:help": "node --import tsx ai-system/cli.ts --help",
    "docker:up": "AI_SYSTEM_SERVER_MODE=true AI_SYSTEM_SERVER_TOKEN=change-me docker compose up -d ai-coding-system",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f ai-coding-system",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "bin": {
    "ai": "./bin/ai.js",
    "ai-system": "./bin/ai-system.js"
  },
  "dependencies": {
    "@types/blessed": "^0.1.27",
    "@xenova/transformers": "^2.17.2",
    "blessed": "^0.1.81"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
