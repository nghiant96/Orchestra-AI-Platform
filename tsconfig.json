{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "**/*.ts",
    "**/*.mts",
    "**/*.cts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".ai-system-artifacts",
    ".ai-system-memory",
    "$tmpdir"
  ]
}
